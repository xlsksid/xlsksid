        <mxCell id="e4" value="提示已支付" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="540" y="1250" width="100" height="40" as="geometry" /></mxCell>

