  <diagram name="订单与支付模块流程图" id="order">
    <mxGraphModel dx="900" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="1400">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        <mxCell id="t" value="订单与支付模块流程图" style="text;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="240" y="20" width="300" height="30" as="geometry" /></mxCell>

        <!-- Customer section -->
        <mxCell id="start" value="开始" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="310" y="70" width="120" height="45" as="geometry" /></mxCell>
        <mxCell id="s1" value="浏览商品" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="145" width="120" height="35" as="geometry" /></mxCell>
        <mxCell id="s2" value="加入购物车" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="205" width="120" height="35" as="geometry" /></mxCell>
        <mxCell id="s3" value="进入购物车" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="265" width="120" height="35" as="geometry" /></mxCell>
        <mxCell id="s4" value="去结算" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="325" width="120" height="35" as="geometry" /></mxCell>
        <mxCell id="s5" value="选择优惠券和积分" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="385" width="120" height="35" as="geometry" /></mxCell>
        <mxCell id="s6" value="提交订单" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="445" width="120" height="35" as="geometry" /></mxCell>

        <!-- Transaction steps -->
        <mxCell id="d1" value="库存充足？" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="280" y="510" width="180" height="65" as="geometry" /></mxCell>
        <mxCell id="e1" value="库存不足\n事务回滚" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="540" y="520" width="100" height="45" as="geometry" /></mxCell>
        
        <mxCell id="s7" value="行锁扣减库存" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="605" width="120" height="35" as="geometry" /></mxCell>
        <mxCell id="d2" value="用了优惠券？" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="280" y="670" width="180" height="65" as="geometry" /></mxCell>
        
        <mxCell id="s8" value="优惠券原子锁定\n计算折扣金额" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="540" y="680" width="110" height="40" as="geometry" /></mxCell>
        
        <mxCell id="s9" value="积分校验扣减\n(按等级汇率)" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1"><mxGeometry x="310" y="765" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="d3" value="积分足够？" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="280" y="835" width="180" height="65" as="geometry" /></mxCell>
        <mxCell id="e3" value="积分不足\n事务回滚" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1"><mxGeometry x="540" y="845" width="100" height="45" as="geometry" /></mxCell>
        
        <mxCell id="s10" value="计算实付金额" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="930" width="120" height="35" as="geometry" /></mxCell>
        <mxCell id="s11" value="生成订单号" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="990" width="120" height="35" as="geometry" /></mxCell>
        <mxCell id="s12" value="创建订单+明细+支付" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="310" y="1050" width="120" height="35" as="geometry" /></mxCell>
