        <mxCell id="a11" value="创建时间" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="340" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a12" value="更新时间" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="260" width="120" height="40" as="geometry" /></mxCell>

