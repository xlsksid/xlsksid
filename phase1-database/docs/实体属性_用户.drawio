<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="用户实体属性图" id="user">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="t" value="用户实体属性图" style="text;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="350" y="10" width="200" height="30" as="geometry" /></mxCell>

        <!-- Center Entity -->
        <mxCell id="center" value="用户" style="rounded=0;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=18;fontStyle=1;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="380" y="300" width="140" height="50" as="geometry" /></mxCell>

        <!-- Top attributes -->
        <mxCell id="a1" value="用户编号" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="380" y="50" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a2" value="用户名" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="530" y="80" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a3" value="密码" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="650" y="150" width="120" height="40" as="geometry" /></mxCell>

        <!-- Right attributes -->
        <mxCell id="a4" value="邮箱" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="260" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a5" value="手机号" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="340" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a6" value="角色" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="680" y="430" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a7" value="头像" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="510" width="120" height="40" as="geometry" /></mxCell>

        <!-- Bottom attributes -->
        <mxCell id="a8" value="账户余额" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="380" y="570" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="a9" value="积分" style="ellipse;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1"><mxGeometry x="200" y="510" width="120" height="40" as="geometry" /></mxCell>

