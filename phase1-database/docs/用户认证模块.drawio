<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="用户认证模块" id="auth">
    <mxGraphModel dx="900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="1000">
      <root>
        <mxCell id="0" /><mxCell id="1" parent="0" />
        
        <mxCell id="title" value="用户认证模块流程图" style="text;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="200" y="20" width="300" height="30" as="geometry" /></mxCell>
        
        <!-- Start -->
        <mxCell id="start" value="开始" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="270" y="70" width="120" height="45" as="geometry" /></mxCell>
        
        <!-- Step 1 -->
        <mxCell id="s1" value="访问系统首页" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="270" y="145" width="120" height="40" as="geometry" /></mxCell>
        
        <!-- Decision 1 -->
        <mxCell id="d1" value="已登录？" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="240" y="220" width="180" height="70" as="geometry" /></mxCell>
        
        <!-- Decision 2 -->
        <mxCell id="d2" value="有账号？" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="70" y="340" width="180" height="70" as="geometry" /></mxCell>
        
        <!-- Login path -->
        <mxCell id="s2" value="输入用户名密码" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="70" y="445" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="s3" value="提交登录请求" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="70" y="510" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="s4" value="后端验证密码哈希" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="70" y="575" width="120" height="40" as="geometry" /></mxCell>
        
        <!-- Decision 3 -->
        <mxCell id="d3" value="验证通过？" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="650" width="180" height="70" as="geometry" /></mxCell>
        
        <!-- Login success -->
        <mxCell id="s5" value="生成JWT令牌" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="755" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="s6" value="前端存储Token" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="820" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="s7" value="登录成功" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="885" width="120" height="40" as="geometry" /></mxCell>
        
        <!-- Login fail -->
        <mxCell id="fail1" value="返回401错误" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="290" y="665" width="120" height="40" as="geometry" /></mxCell>
        
        <!-- Register path -->
        <mxCell id="s8" value="填写注册信息" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="480" y="355" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="s9" value="BCrypt加密密码" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="480" y="420" width="120" height="40" as="geometry" /></mxCell>
        <mxCell id="s10" value="写入users表" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="480" y="485" width="120" height="40" as="geometry" /></mxCell>
        
        <!-- Already logged in path -->
        <mxCell id="s11" value="读取localStorage Token" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="460" y="235" width="130" height="40" as="geometry" /></mxCell>
        <mxCell id="d4" value="Token过期？" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="460" y="315" width="160" height="70" as="geometry" /></mxCell>
        <mxCell id="s12" value="清除缓存跳转登录" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="620" y="335" width="120" height="40" as="geometry" /></mxCell>
        
        <!-- Register success merge -->
        <mxCell id="s13" value="生成JWT并返回" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="480" y="550" width="120" height="40" as="geometry" /></mxCell>
        
        <!-- End -->
        <mxCell id="end" value="结束" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1"><mxGeometry x="270" y="950" width="120" height="45" as="geometry" /></mxCell>

        <!-- Edges -->
        <mxCell edge="1" parent="1" source="start" target="s1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="s1" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        
        <mxCell id="e1" edge="1" parent="1" source="d1" target="d2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1t" value="否" style="edgeLabel;fontSize=10;fontColor=#cc0000;" vertex="1" connectable="0" parent="e1"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        
        <mxCell id="e2" edge="1" parent="1" source="d1" target="s11"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2t" value="是" style="edgeLabel;fontSize=10;fontColor=#009900;" vertex="1" connectable="0" parent="e2"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        
        <mxCell id="e3" edge="1" parent="1" source="d2" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3t" value="是" style="edgeLabel;fontSize=10;fontColor=#009900;" vertex="1" connectable="0" parent="e3"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        
        <mxCell id="e4" edge="1" parent="1" source="d2" target="s8"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4t" value="否" style="edgeLabel;fontSize=10;fontColor=#cc0000;" vertex="1" connectable="0" parent="e4"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        
        <mxCell edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="s4" target="d3"><mxGeometry relative="1" as="geometry" /></mxCell>
        
        <mxCell id="e5" edge="1" parent="1" source="d3" target="s5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5t" value="是" style="edgeLabel;fontSize=10;fontColor=#009900;" vertex="1" connectable="0" parent="e5"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        
        <mxCell id="e6" edge="1" parent="1" source="d3" target="fail1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6t" value="否" style="edgeLabel;fontSize=10;fontColor=#cc0000;" vertex="1" connectable="0" parent="e6"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        
        <mxCell edge="1" parent="1" source="s5" target="s6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="s6" target="s7"><mxGeometry relative="1" as="geometry" /></mxCell>
        
        <mxCell edge="1" parent="1" source="s8" target="s9"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="s9" target="s10"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="s10" target="s13"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell edge="1" parent="1" source="s13" target="s7"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="650"/><mxPoint x="100" y="650"/></Array></mxGeometry></mxCell>
        
        <mxCell edge="1" parent="1" source="s11" target="d4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" edge="1" parent="1" source="d4" target="s12"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7t" value="是" style="edgeLabel;fontSize=10;fontColor=#cc0000;" vertex="1" connectable="0" parent="e7"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        <mxCell edge="1" parent="1" source="s12" target="d2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="680" y="375"/></Array></mxGeometry></mxCell>
        <mxCell id="e8" edge="1" parent="1" source="d4" target="d1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="540" y="255"/></Array></mxGeometry></mxCell>
        <mxCell id="e8t" value="否" style="edgeLabel;fontSize=10;fontColor=#009900;" vertex="1" connectable="0" parent="e8"><mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        
        <mxCell edge="1" parent="1" source="s7" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>
